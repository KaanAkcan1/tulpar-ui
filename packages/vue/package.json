{
  "name": "@tulpar-ui/vue",
  "version": "0.7.0",
  "description": "Vue 3 wrappers for Tulpar UI Web Components",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tulpar-ui/core": "workspace:*",
    "@tulpar-ui/shell": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.5.0",
    "vue-router": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "vue-router": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tulpar-ui/core": "workspace:*",
    "@tulpar-ui/shell": "workspace:*",
    "vue-router": "^4.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "happy-dom": "^14.0.0",
    "vite": "^5.1.0",
    "vite-plugin-dts": "catalog:",
    "vitest": "^1.3.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
