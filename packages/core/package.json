{
  "name": "@tulpar-ui/core",
  "version": "0.6.0",
  "description": "Lit Web Components for Tulpar UI",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./button": {
      "types": "./dist/button/index.d.ts",
      "import": "./dist/button/index.js"
    },
    "./button-group": {
      "types": "./dist/button-group/index.d.ts",
      "import": "./dist/button-group/index.js"
    },
    "./number-input": {
      "types": "./dist/number-input/index.d.ts",
      "import": "./dist/number-input/index.js"
    },
    "./text-input": {
      "types": "./dist/text-input/index.d.ts",
      "import": "./dist/text-input/index.js"
    },
    "./textarea": {
      "types": "./dist/textarea/index.d.ts",
      "import": "./dist/textarea/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "sync-exports": "tsx build/sync-exports.ts",
    "sync-exports:check": "tsx build/sync-exports.ts --check",
    "prebuild": "tsx build/sync-exports.ts",
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "wtr",
    "test:watch": "wtr --watch"
  },
  "dependencies": {
    "lit": "catalog:",
    "@tulpar-ui/tokens": "workspace:*"
  },
  "devDependencies": {
    "@open-wc/testing": "^4.0.0",
    "@tulpar-ui/tokens": "workspace:*",
    "@types/mocha": "^10.0.6",
    "@web/dev-server-esbuild": "^1.0.0",
    "@web/test-runner": "^0.20.0",
    "@web/test-runner-playwright": "^0.11.0",
    "playwright": "^1.60.0",
    "tsx": "^4.7.0",
    "vite": "^5.1.0",
    "vite-plugin-dts": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
