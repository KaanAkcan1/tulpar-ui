{
  "name": "@tulpar-ui/angular",
  "version": "0.0.0",
  "description": "Angular wrappers for Tulpar UI Web Components",
  "type": "module",
  "main": "./dist/fesm2022/tulpar-ui-angular.mjs",
  "module": "./dist/fesm2022/tulpar-ui-angular.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/fesm2022/tulpar-ui-angular.mjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "ng-packagr -p ng-package.json -c tsconfig.json",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@angular/common": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@tulpar-ui/core": "workspace:*",
    "lucide-angular": ">=0.400.0"
  },
  "devDependencies": {
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/compiler-cli": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@tulpar-ui/core": "workspace:*",
    "happy-dom": "^14.0.0",
    "lucide-angular": ">=0.400.0",
    "ng-packagr": "^20.0.0",
    "vitest": "^1.3.0",
    "zone.js": "^0.15.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
