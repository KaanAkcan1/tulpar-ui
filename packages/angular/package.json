{
  "name": "@tulpar-ui/angular",
  "version": "0.0.0",
  "description": "Angular wrappers for Tulpar UI Web Components",
  "type": "module",
  "main": "./dist/fesm2022/tulpar-ui-angular.mjs",
  "module": "./dist/fesm2022/tulpar-ui-angular.mjs",
  "types": "./dist/types/tulpar-ui-angular.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/tulpar-ui-angular.d.ts",
      "import": "./dist/fesm2022/tulpar-ui-angular.mjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "ng-packagr -p ng-package.json -c tsconfig.json",
    "dev": "ng-packagr -p ng-package.json -c tsconfig.json --watch",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@angular/common": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@tulpar-ui/core": "workspace:*",
    "lucide-angular": ">=0.500.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.6.0",
    "@analogjs/vitest-angular": "^2.6.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-browser-dynamic": "^22.0.0",
    "@tulpar-ui/core": "workspace:*",
    "happy-dom": "^20.0.0",
    "lucide-angular": ">=0.500.0",
    "ng-packagr": "^22.0.0",
    "vite": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
