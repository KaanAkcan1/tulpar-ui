{
  "name": "@tulpar-ui/shell",
  "version": "0.7.0",
  "description": "Application shell components for Tulpar UI",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./nav-item": {
      "types": "./dist/nav-item/index.d.ts",
      "import": "./dist/nav-item/index.js"
    },
    "./nav-section": {
      "types": "./dist/nav-section/index.d.ts",
      "import": "./dist/nav-section/index.js"
    },
    "./persist": {
      "types": "./dist/persist/index.d.ts",
      "import": "./dist/persist/index.js"
    },
    "./shell": {
      "types": "./dist/shell/index.d.ts",
      "import": "./dist/shell/index.js"
    },
    "./sidenav": {
      "types": "./dist/sidenav/index.d.ts",
      "import": "./dist/sidenav/index.js"
    },
    "./topbar": {
      "types": "./dist/topbar/index.d.ts",
      "import": "./dist/topbar/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "sync-exports": "tsx build/sync-exports.ts",
    "sync-exports:check": "tsx build/sync-exports.ts --check",
    "prebuild": "tsx build/sync-exports.ts",
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "wtr",
    "test:watch": "wtr --watch"
  },
  "dependencies": {
    "lit": "catalog:"
  },
  "devDependencies": {
    "@open-wc/testing": "^4.0.0",
    "@tulpar-ui/tokens": "workspace:*",
    "@types/mocha": "^10.0.6",
    "@web/dev-server-esbuild": "^1.0.0",
    "@web/test-runner": "^0.20.0",
    "@web/test-runner-commands": "^0.9.0",
    "@web/test-runner-playwright": "^0.11.0",
    "tsx": "^4.7.0",
    "vite": "^5.1.0",
    "vite-plugin-dts": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
