# pnpm does NOT run pre/post lifecycle scripts by default (unlike npm).
# The dev loop contract documented in CLAUDE.md relies on predev/predev:ng/
# predev:vue/predev:storybook running a full topological package build before
# the parallel watch starts — without this flag those scripts silently never
# ran, causing cold-start type-resolution races and stale dist in dev.
enable-pre-post-scripts=true
