{
  "name": "tulpar-ui",
  "version": "0.0.0",
  "private": true,
  "description": "Tulpar UI — Lit-based design system with Angular and Vue wrappers",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter=\"./packages/*\" run build",
    "predev:ng": "pnpm -r --filter=\"./packages/*\" run build && pnpm --filter playground-ng exec ng cache clean",
    "dev:ng": "pnpm --parallel --filter @tulpar-ui/tokens --filter @tulpar-ui/core --filter @tulpar-ui/shell --filter @tulpar-ui/angular --filter playground-ng run dev",
    "predev:vue": "pnpm -r --filter=\"./packages/*\" run build",
    "dev:vue": "pnpm --parallel --filter @tulpar-ui/tokens --filter @tulpar-ui/core --filter @tulpar-ui/shell --filter @tulpar-ui/vue --filter playground-vue run dev",
    "predev:storybook": "pnpm -r --filter=\"./packages/*\" run build",
    "dev:storybook": "pnpm --parallel --filter @tulpar-ui/tokens --filter @tulpar-ui/core --filter @tulpar-ui/shell --filter docs run dev",
    "predev": "pnpm -r --filter=\"./packages/*\" run build && pnpm --filter playground-ng exec ng cache clean",
    "dev": "pnpm --parallel --filter @tulpar-ui/tokens --filter @tulpar-ui/core --filter @tulpar-ui/shell --filter @tulpar-ui/angular --filter @tulpar-ui/vue --filter playground-ng --filter playground-vue --filter docs run dev",
    "test": "pnpm -r run test",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,js,json,md,css,html,vue}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,css,html,vue}\"",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.2.0",
    "typescript": "^6.0.0",
    "wrangler": "^4.98.0"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22.22.3",
    "pnpm": ">=9.0.0"
  },
  "lint-staged": {
    "**/*.{ts,js,json,md,css,html,vue}": "prettier --write"
  }
}
