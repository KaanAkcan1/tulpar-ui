{
  "name": "tulpar-ui",
  "version": "0.0.0",
  "private": true,
  "description": "Tulpar UI — Lit-based design system with Angular and Vue wrappers",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter=\"./packages/*\" run build",
    "test": "pnpm -r run test",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,js,json,md,css,html,vue}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,css,html,vue}\"",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^9.39.4",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=22.22.3",
    "pnpm": ">=8.15.0"
  }
}
